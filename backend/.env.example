# ═══════════════════════════════════════════════════════════════
# QueryCopilot — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED: Anthropic API Key ────────────────────────────────
# Get yours at: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Database Connection ────────────────────────────────────────
# Supported types: postgresql, mysql, bigquery, snowflake
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password
DB_SCHEMA=public

# ── BigQuery (if DB_TYPE=bigquery) ─────────────────────────────
# BQ_PROJECT=your-gcp-project
# BQ_DATASET=your_dataset
# BQ_CREDENTIALS_PATH=/path/to/service-account.json

# ── Snowflake (if DB_TYPE=snowflake) ───────────────────────────
# SF_ACCOUNT=your_account.us-east-1
# SF_WAREHOUSE=COMPUTE_WH
# SF_DATABASE=ANALYTICS
# SF_SCHEMA=PUBLIC

# ── OAuth — Google ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# ── OAuth — GitHub ─────────────────────────────────────────────
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── OAuth Redirect URI ─────────────────────────────────────────
OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# ── Email Delivery (for OTP) ──────────────────────────────────
# OPTION 1 (Recommended): Resend — free 100 emails/day
# Sign up at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=QueryCopilot <onboarding@resend.dev>

# OPTION 2: SMTP (Gmail App Password, SendGrid, Brevo, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=QueryCopilot

# ── SMS Delivery (Phone OTP via Twilio) ───────────────────────
# Sign up at https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Model Configuration ───────────────────────────────────────
PRIMARY_MODEL=claude-haiku-4-5-20251001
FALLBACK_MODEL=claude-sonnet-4-6

# ── Security Settings ─────────────────────────────────────────
MAX_ROWS=1000
QUERY_TIMEOUT_SECONDS=30

# ── Caching ───────────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
